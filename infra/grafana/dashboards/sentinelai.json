{
  "title": "SentinelAI Overview",
  "uid": "sentinelai",
  "schemaVersion": 38,
  "refresh": "10s",
  "panels": [
    {
      "id": 1, "type": "stat", "title": "Total LLM Requests",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [{ "expr": "sum(sentinelai_llm_requests_total)", "legendFormat": "Requests" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },
    {
      "id": 2, "type": "stat", "title": "Request Rate (rpm)",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [{ "expr": "sum(rate(sentinelai_llm_requests_total[1m])) * 60", "legendFormat": "RPM" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },
    {
      "id": 3, "type": "stat", "title": "Total Tokens Used",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "targets": [{ "expr": "sum(sentinelai_llm_tokens_total)", "legendFormat": "Tokens" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },
    {
      "id": 4, "type": "stat", "title": "Guardrails Triggered",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "targets": [{ "expr": "sum(sentinelai_guardrails_triggered_total)", "legendFormat": "Triggers" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "thresholds": { "steps": [{ "color": "green", "value": 0 }, { "color": "red", "value": 1 }] } }
    },
    {
      "id": 5, "type": "timeseries", "title": "Request Rate over Time",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        { "expr": "sum by(status) (rate(sentinelai_llm_requests_total[1m])) * 60", "legendFormat": "{{status}}" }
      ]
    },
    {
      "id": 6, "type": "timeseries", "title": "LLM Latency (p50 / p95 / p99)",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum by(le) (rate(sentinelai_llm_latency_seconds_bucket[5m])))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, sum by(le) (rate(sentinelai_llm_latency_seconds_bucket[5m])))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, sum by(le) (rate(sentinelai_llm_latency_seconds_bucket[5m])))", "legendFormat": "p99" }
      ]
    },
    {
      "id": 7, "type": "timeseries", "title": "Tokens per Minute",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [
        { "expr": "sum by(type) (rate(sentinelai_llm_tokens_total[1m])) * 60", "legendFormat": "{{type}}" }
      ]
    },
    {
      "id": 8, "type": "piechart", "title": "Requests by Model",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [
        { "expr": "sum by(model) (sentinelai_llm_requests_total)", "legendFormat": "{{model}}" }
      ]
    }
  ],
  "time": { "from": "now-1h", "to": "now" }
}
